{% assign project = include.project %}
<a class="project-hero-link" href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}">
  <div class="project-hero">
    {% if project.img %}
      <div class="project-hero__media">
        {%
          include figure.liquid
          loading="eager"
          path=project.img
          sizes="(max-width: 768px) 100vw, 50vw"
          alt=project.title
          class="project-hero__img rounded"
        %}
      </div>
    {% endif %}
    <div class="project-hero__body">
      <span class="kicker">Featured · {{ project.category }}</span>
      <h2 class="project-hero__title">{{ project.title }}</h2>
      <p class="project-hero__desc">{{ project.description }}</p>
      <span class="btn-companion project-hero__cta">View project</span>
    </div>
  </div>
</a>
